{
  "name": "onyx",
  "version": "1.0.0",
  "description": "A centralized power toolkit and system guard for developers",
  "author": "Sepd0x",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sepd0x/onyx.git"
  },
  "main": "packages/core/src/main.js",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cd packages/ui && vite --host 0.0.0.0 --port 3000",
    "start": "electron packages/core",
    "start-desktop": "cross-env NODE_ENV=development electron packages/core",
    "onyx": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run start-desktop\"",
    "build:ui": "npm run build --workspace=packages/ui",
    "build": "npm run build:ui && electron-builder",
    "generate:icon": "node scripts/generate-icon.js",
    "typecheck": "npm run typecheck --workspace=packages/ui",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.onyx.app",
    "productName": "Onyx",
    "publish": [
      "github"
    ],
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "packages/tools/cursor-autohide/backend.ps1"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    },
    "files": [
      "packages/core/**/*",
      "!packages/**/test/**",
      "!packages/**/*.test.js",
      "packages/ui/dist/**/*",
      "packages/tools/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.0",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "electron-updater": "^6.8.9"
  }
}
